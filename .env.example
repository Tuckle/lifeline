# Update these with your Supabase details from your project settings > API.
# Do not put service-role keys, import tokens, or other private secrets in NEXT_PUBLIC_* values.
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Server-side only. Used for the personal MVP RescueTime import path.
RESCUETIME_API_KEY=your-rescuetime-api-key

# Configure Google OAuth inside Supabase Auth provider settings.
# Local Supabase redirect allow-list should include:
# http://localhost:3000/auth/callback
